#!/usr/bin/env bash
# minions — Execute a queue of AI CLI prompts sequentially
# Usage: minions --queue <file.yaml> [options]
set -euo pipefail

VERSION="1.0.0"

# ─── Colors ──────────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
DIM='\033[2m'
BOLD='\033[1m'
NC='\033[0m' # No Color

# ─── Defaults ────────────────────────────────────────────────────────────────────
QUEUE_FILE=""
WORKDIR="."
APPROVAL_MODE="yolo"
DRY_RUN=false
PARALLEL=false
CONTINUE_ON_ERROR=false
MODEL=""
CLI="pi"
if [[ -f ~/.minionsrc ]]; then
  source ~/.minionsrc
  [[ -n "${DEFAULT_CLI:-}" ]] && CLI="$DEFAULT_CLI"
fi
SANDBOX=false
DELAY=2
LOG_DIR="./runs"

# ─── Helpers ─────────────────────────────────────────────────────────────────────
die()  { echo -e "${RED}❌ $*${NC}" >&2; exit 1; }
info() { echo -e "${BLUE}▶${NC} $*"; }
ok()   { echo -e "${GREEN}✅ $*${NC}"; }
warn() { echo -e "${YELLOW}⚠️  $*${NC}"; }
dim()  { echo -e "${DIM}$*${NC}"; }

usage() {
  cat <<EOF
minions v${VERSION} — Batch prompt scheduler for AI CLIs

USAGE
  minions --queue <file.yaml> [options]
  minions cli        (Select default AI CLI)
  minions init       (Initialize Fikr skill)

OPTIONS
  --queue <file>     Path to YAML queue file (required)
  --cli <name>       Target CLI (default: pi)
  --workdir <dir>    Working directory (default: .)
  --approval-mode    yolo (default), auto_edit, default
  --model <model>    Override AI model
  --dry-run          Print prompts without executing
  --parallel         Run all prompts concurrently
  --sandbox          Run in sandbox mode
  --help             Show this help
EOF
}

# ─── Init Command ────────────────────────────────────────────────────────────────
if [[ $# -gt 0 && "$1" == "init" ]]; then
  SOURCE="${BASH_SOURCE[0]}"
  while [ -h "$SOURCE" ]; do
    DIR="$( cd -P "$( dirname "$SOURCE" )" >/dev/null 2>&1 && pwd )"
    SOURCE="$(readlink "$SOURCE")"
    [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
  done
  REPO_DIR="$( cd -P "$( dirname "$SOURCE" )" >/dev/null 2>&1 && pwd )"

  TARGET_DIR=".agents/skills/minions"
  echo -e "${CYAN}Initializing minions skill in $TARGET_DIR...${NC}"
  mkdir -p "$TARGET_DIR"
  
  if [[ -f "$REPO_DIR/base-skill.md" ]]; then
    cp "$REPO_DIR/base-skill.md" "$TARGET_DIR/SKILL.md"
    echo -e "${GREEN}✅ Successfully copied base skill to $TARGET_DIR/SKILL.md${NC}"
  else
    echo -e "${RED}❌ Could not find base skill file in $REPO_DIR${NC}"
    exit 1
  fi
  exit 0
fi

# ─── CLI Selection Command ───────────────────────────────────────────────────────
if [[ $# -gt 0 && "$1" == "cli" ]]; then
  echo -e "${CYAN}Scanning for installed AI CLIs...${NC}"
  KNOWN_CLIS=("pi" "gemini" "claude" "chatgpt" "aider" "copilot" "fabric" "cursor-agent" "ubot")
  INSTALLED=()
  for c in "${KNOWN_CLIS[@]}"; do
    if command -v "$c" &>/dev/null; then
      INSTALLED+=("$c")
    fi
  done
  
  if [[ ${#INSTALLED[@]} -eq 0 ]]; then
    echo -e "${RED}No known AI CLIs found installed on your system.${NC}"
    exit 1
  fi
  
  echo -e "\n${BOLD}Select your default AI CLI for Minions:${NC}"
  PS3="Enter number: "
  select opt in "${INSTALLED[@]}" "Cancel"; do
    if [[ "$opt" == "Cancel" ]]; then
      exit 0
    elif [[ -n "$opt" ]]; then
      echo "DEFAULT_CLI=\"$opt\"" > ~/.minionsrc
      echo -e "${GREEN}✅ Default CLI set to '${BOLD}$opt${NC}${GREEN}' globally!${NC}"
      exit 0
    else
      echo "Invalid option. Try again."
    fi
  done
  exit 0
fi

# ─── Parse Args ──────────────────────────────────────────────────────────────────
if [[ $# -eq 0 ]]; then
  usage
  exit 1
fi

while [[ $# -gt 0 ]]; do
  case "$1" in
    --queue)           QUEUE_FILE="$2"; shift 2 ;;
    --workdir)         WORKDIR="$2"; shift 2 ;;
    --approval-mode)   APPROVAL_MODE="$2"; shift 2 ;;
    --dry-run)         DRY_RUN=true; shift ;;
    --parallel)        PARALLEL=true; shift ;;
    --continue-on-error) CONTINUE_ON_ERROR=true; shift ;;
    --model)           MODEL="$2"; shift 2 ;;
    --cli)             CLI="$2"; shift 2 ;;
    --sandbox)         SANDBOX=true; shift ;;
    --delay)           DELAY="$2"; shift 2 ;;
    --log-dir)         LOG_DIR="$2"; shift 2 ;;
    --version)         echo "pi v${VERSION}"; exit 0 ;;
    --help|-h)         usage; exit 0 ;;
    *)                 die "Unknown option: $1. Use --help for usage." ;;
  esac
done

# ─── Validate ────────────────────────────────────────────────────────────────────
[[ -z "$QUEUE_FILE" ]] && die "Missing required --queue <file.yaml>. Use --help for usage."
[[ ! -f "$QUEUE_FILE" ]] && die "Queue file not found: $QUEUE_FILE"
command -v "$CLI" &>/dev/null || warn "Executable '$CLI' not found in path"

case "$APPROVAL_MODE" in
  default|auto_edit|yolo) ;;
  *) die "Invalid approval mode: $APPROVAL_MODE. Must be: default, auto_edit, or yolo" ;;
esac

# Resolve absolute paths
WORKDIR="$(cd "$WORKDIR" 2>/dev/null && pwd)" || die "Working directory not found: $WORKDIR"
QUEUE_FILE="$(cd "$(dirname "$QUEUE_FILE")" && pwd)/$(basename "$QUEUE_FILE")"

# ─── YAML Parser (lightweight, no dependencies) ─────────────────────────────────
# Parses the simple queue YAML format into arrays
parse_queue() {
  local file="$1"
  local in_queue=false
  local current_name=""
  local current_prompt=""
  local current_workdir=""
  local current_model=""
  local current_cli=""
  local current_approval=""
  local item_index=0

  QUEUE_NAMES=()
  QUEUE_PROMPTS=()
  QUEUE_WORKDIRS=()
  QUEUE_MODELS=()
  QUEUE_CLIS=()
  QUEUE_APPROVALS=()

  while IFS= read -r line || [[ -n "$line" ]]; do
    # Strip comments (but not inside quotes)
    local stripped="${line%%#*}"
    # Skip empty lines
    [[ -z "${stripped// /}" ]] && continue

    # Detect queue start
    if [[ "$stripped" =~ ^queue: ]]; then
      in_queue=true
      continue
    fi

    if ! $in_queue; then
      continue
    fi

    # Detect new list item (starts with " - " or "  - ")
    if [[ "$stripped" =~ ^[[:space:]]*-[[:space:]] ]]; then
      # Save previous item if exists
      if [[ -n "$current_name" || -n "$current_prompt" ]]; then
        QUEUE_NAMES+=("$current_name")
        QUEUE_PROMPTS+=("$current_prompt")
        QUEUE_WORKDIRS+=("$current_workdir")
        QUEUE_MODELS+=("$current_model")
        QUEUE_CLIS+=("$current_cli")
        QUEUE_APPROVALS+=("$current_approval")
        item_index=$((item_index + 1))
      fi
      # Reset for new item
      current_name=""
      current_prompt=""
      current_workdir=""
      current_model=""
      current_cli=""
      current_approval=""

      # Check if key:value is on the same line as the dash
      local after_dash="${stripped#*- }"
      if [[ "$after_dash" =~ ^name:[[:space:]]*(.*) ]]; then
        current_name="${BASH_REMATCH[1]}"
        current_name="${current_name#\"}"
        current_name="${current_name%\"}"
        current_name="${current_name#\'}"
        current_name="${current_name%\'}"
      elif [[ "$after_dash" =~ ^prompt:[[:space:]]*(.*) ]]; then
        current_prompt="${BASH_REMATCH[1]}"
        current_prompt="${current_prompt#\"}"
        current_prompt="${current_prompt%\"}"
        current_prompt="${current_prompt#\'}"
        current_prompt="${current_prompt%\'}"
      fi
      continue
    fi

    # Parse key: value lines within an item
    if [[ "$stripped" =~ ^[[:space:]]+name:[[:space:]]*(.*) ]]; then
      current_name="${BASH_REMATCH[1]}"
      current_name="${current_name#\"}"
      current_name="${current_name%\"}"
      current_name="${current_name#\'}"
      current_name="${current_name%\'}"
    elif [[ "$stripped" =~ ^[[:space:]]+prompt:[[:space:]]*(.*) ]]; then
      current_prompt="${BASH_REMATCH[1]}"
      current_prompt="${current_prompt#\"}"
      current_prompt="${current_prompt%\"}"
      current_prompt="${current_prompt#\'}"
      current_prompt="${current_prompt%\'}"
    elif [[ "$stripped" =~ ^[[:space:]]+workdir:[[:space:]]*(.*) ]]; then
      current_workdir="${BASH_REMATCH[1]}"
      current_workdir="${current_workdir#\"}"
      current_workdir="${current_workdir%\"}"
      current_workdir="${current_workdir#\'}"
      current_workdir="${current_workdir%\'}"
    elif [[ "$stripped" =~ ^[[:space:]]+model:[[:space:]]*(.*) ]]; then
      current_model="${BASH_REMATCH[1]}"
      current_model="${current_model#\"}"
      current_model="${current_model%\"}"
      current_model="${current_model#\'}"
      current_model="${current_model%\'}"
    elif [[ "$stripped" =~ ^[[:space:]]+cli:[[:space:]]*(.*) ]]; then
      current_cli="${BASH_REMATCH[1]}"
      current_cli="${current_cli#\"}"
      current_cli="${current_cli%\"}"
      current_cli="${current_cli#\'}"
      current_cli="${current_cli%\'}"
    elif [[ "$stripped" =~ ^[[:space:]]+approval_mode:[[:space:]]*(.*) ]]; then
      current_approval="${BASH_REMATCH[1]}"
      current_approval="${current_approval#\"}"
      current_approval="${current_approval%\"}"
      current_approval="${current_approval#\'}"
      current_approval="${current_approval%\'}"
    fi
  done < "$file"

  # Save last item
  if [[ -n "$current_name" || -n "$current_prompt" ]]; then
    QUEUE_NAMES+=("$current_name")
    QUEUE_PROMPTS+=("$current_prompt")
    QUEUE_WORKDIRS+=("$current_workdir")
    QUEUE_MODELS+=("$current_model")
    QUEUE_CLIS+=("$current_cli")
    QUEUE_APPROVALS+=("$current_approval")
  fi
}

# ─── Build CLI Command ────────────────────────────────────────────────────────
build_cli_cmd() {
  local prompt="$1"
  local item_workdir="$2"
  local item_model="$3"
  local item_approval="$4"
  local item_cli="$5"

  local target_cli="${item_cli:-$CLI}"
  local cmd=("$target_cli")

  # Approval mode (per-prompt override or global)
  local approval="${item_approval:-$APPROVAL_MODE}"
  cmd+=("--approval-mode" "$approval")

  # Model (per-prompt override or global)
  local model="${item_model:-$MODEL}"
  if [[ -n "$model" ]]; then
    cmd+=("-m" "$model")
  fi

  # Sandbox
  if $SANDBOX; then
    cmd+=("--sandbox")
  fi

  # The prompt itself (as positional argument)
  cmd+=("$prompt")

  printf "%q " "${cmd[@]}"
}

# ─── Main Execution ─────────────────────────────────────────────────────────────
main() {
  echo ""
  echo -e "${BOLD}${CYAN}⚡ minions${NC} v${VERSION}"
  echo -e "${DIM}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

  # Parse the queue file
  parse_queue "$QUEUE_FILE"
  local total=${#QUEUE_NAMES[@]}

  if [[ $total -eq 0 ]]; then
    die "No prompts found in queue file: $QUEUE_FILE"
  fi

  info "Queue:     ${BOLD}$QUEUE_FILE${NC}"
  info "Prompts:   ${BOLD}$total${NC}"
  info "Workdir:   ${BOLD}$WORKDIR${NC}"
  info "Approval:  ${BOLD}$APPROVAL_MODE${NC}"
  if [[ -n "$MODEL" ]]; then
    info "Model:     ${BOLD}$MODEL${NC}"
  fi
  info "Target CLI:${BOLD}$CLI${NC}"
  if $SANDBOX; then
    info "Sandbox:   ${BOLD}enabled${NC}"
  fi
  if $PARALLEL; then
    info "Mode:      ${BOLD}PARALLEL${NC}"
  fi
  if $DRY_RUN; then
    info "Mode:      ${BOLD}${YELLOW}DRY RUN${NC}"
  fi
  echo -e "${DIM}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo ""

  # Setup log directory & file
  local run_timestamp
  run_timestamp=$(date +"%Y%m%d_%H%M%S")
  local log_file="${LOG_DIR}/run-${run_timestamp}.log"

  if ! $DRY_RUN; then
    mkdir -p "$LOG_DIR"
    {
      echo "# minions run log"
      echo "# Started: $(date -u '+%Y-%m-%dT%H:%M:%SZ')"
      echo "# Queue:   $QUEUE_FILE"
      echo "# Workdir: $WORKDIR"
      echo "# Prompts: $total"
      echo "# Approval: $APPROVAL_MODE"
      echo ""
    } > "$log_file"
  fi

  # Execute prompts
  local PIDS=()
  local START_TIMES=()
  local EXIT_CODES=()
  local passed=0
  local failed=0
  local skipped=0

  for i in $(seq 0 $((total - 1))); do
    local name="${QUEUE_NAMES[$i]}"
    local prompt="${QUEUE_PROMPTS[$i]}"
    local item_workdir="${QUEUE_WORKDIRS[$i]}"
    local item_model="${QUEUE_MODELS[$i]}"
    local item_cli="${QUEUE_CLIS[$i]}"
    local item_approval="${QUEUE_APPROVALS[$i]}"
    local step_num=$((i + 1))

    echo -e "${BOLD}[${step_num}/${total}]${NC} ${CYAN}${name}${NC}"

    if $DRY_RUN; then
      dim "  prompt: ${prompt}"
      local wd="${item_workdir:-$WORKDIR}"
      dim "  workdir: ${wd}"
      dim "  approval: ${item_approval:-$APPROVAL_MODE}"
      dim "  cli: ${item_cli:-$CLI}"
      if [[ -n "$item_model" ]]; then
        dim "  model: ${item_model}"
      fi
      echo ""
      continue
    fi

    # Resolve working directory
    local wd="${item_workdir:-$WORKDIR}"
    if [[ ! -d "$wd" ]]; then
      warn "Working directory not found: $wd — skipping"
      skipped=$((skipped + 1))
      echo "## [${step_num}/${total}] ${name}" >> "$log_file"
      echo "Status: SKIPPED (workdir not found: $wd)" >> "$log_file"
      echo "" >> "$log_file"
      continue
    fi

    # Build the command
    local run_cmd
    run_cmd=$(build_cli_cmd "$prompt" "$item_workdir" "$item_model" "$item_approval" "$item_cli")

    # Log start
    local start_time
    start_time=$(date +%s)
    local start_timestamp
    start_timestamp=$(date -u '+%Y-%m-%dT%H:%M:%SZ')

    {
      echo "## [${step_num}/${total}] ${name}"
      echo "Start:   ${start_timestamp}"
      echo "Workdir: ${wd}"
      echo "Command: ${run_cmd}"
      echo ""
    } >> "$log_file"

    dim "  → Running in ${wd}..."

    # Execute
    local exit_code=0
    local output_file="${LOG_DIR}/.prompt-${step_num}-output.tmp"

    if $PARALLEL; then
      (cd "$wd" && eval "$run_cmd" > "$output_file" 2>&1; echo $? > "${output_file}.exit") &
      PIDS[$i]=$!
      START_TIMES[$i]=$start_time
      continue
    fi
    if (cd "$wd" && eval "$run_cmd" > "$output_file" 2>&1); then
      exit_code=0
    else
      exit_code=$?
    fi

    local end_time
    end_time=$(date +%s)
    local duration=$((end_time - start_time))

    # Capture output summary (first/last 20 lines)
    local output_summary=""
    if [[ -f "$output_file" ]]; then
      local line_count
      line_count=$(wc -l < "$output_file" | tr -d ' ')
      if [[ $line_count -le 40 ]]; then
        output_summary=$(cat "$output_file")
      else
        output_summary=$(head -20 "$output_file")
        output_summary+=$'\n... ('"$((line_count - 40))"' lines omitted) ...\n'
        output_summary+=$(tail -20 "$output_file")
      fi
    fi

    # Log result
    {
      echo "Exit:    ${exit_code}"
      echo "Duration: ${duration}s"
      echo "End:     $(date -u '+%Y-%m-%dT%H:%M:%SZ')"
      echo ""
      echo "### Output"
      echo '```'
      echo "$output_summary"
      echo '```'
      echo ""
      echo "---"
      echo ""
    } >> "$log_file"

    # Clean up temp file
    rm -f "$output_file"

    if [[ $exit_code -eq 0 ]]; then
      ok "  Completed in ${duration}s"
      passed=$((passed + 1))
    else
      echo -e "  ${RED}✗ Failed (exit code: ${exit_code}) after ${duration}s${NC}"
      failed=$((failed + 1))

      if ! $CONTINUE_ON_ERROR; then
        warn "Aborting. Use --continue-on-error to keep going."
        break
      fi
    fi

    # Delay between prompts (except after the last one)
    if [[ $i -lt $((total - 1)) ]] && [[ $DELAY -gt 0 ]]; then
      dim "  Waiting ${DELAY}s before next prompt..."
      sleep "$DELAY"
    fi

    echo ""
  done


  if $PARALLEL; then
    dim "Waiting for background agents to finish..."
    wait

    for i in $(seq 0 $((total - 1))); do
      local name="${QUEUE_NAMES[$i]}"
      local step_num=$((i + 1))
      local output_file="${LOG_DIR}/.prompt-${step_num}-output.tmp"
      local exit_code_file="${output_file}.exit"
      
      if [[ -f "$exit_code_file" ]]; then
        local exit_code=$(cat "$exit_code_file")
        local start_time=${START_TIMES[$i]}
        local end_time=$(date +%s)
        local duration=$((end_time - start_time))
        
        local output_summary=""
        if [[ -f "$output_file" ]]; then
          local line_count=$(wc -l < "$output_file" | tr -d ' ')
          if [[ $line_count -le 40 ]]; then
            output_summary=$(cat "$output_file")
          else
            output_summary=$(head -20 "$output_file")
            output_summary+=$'\n... ('"$((line_count - 40))"' lines omitted) ...\n'
            output_summary+=$(tail -20 "$output_file")
          fi
        fi

        {
          echo "Exit:    ${exit_code}"
          echo "Duration: ${duration}s"
          echo "End:     $(date -u '+%Y-%m-%dT%H:%M:%SZ')"
          echo ""
          echo "### Output"
          echo '```'
          echo "$output_summary"
          echo '```'
          echo ""
          echo "---"
          echo ""
        } >> "$log_file"

        rm -f "$output_file" "$exit_code_file"

        if [[ $exit_code -eq 0 ]]; then
          ok "[${step_num}/${total}] ${name} completed in ${duration}s"
          passed=$((passed + 1))
        else
          echo -e "${RED}✗ [${step_num}/${total}] ${name} failed (exit code: ${exit_code}) after ${duration}s${NC}"
          failed=$((failed + 1))
        fi
      fi
    done
  fi
  # ─── Summary ────────────────────────────────────────────────────────────────────
  echo -e "${DIM}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

  if $PARALLEL; then
    info "Mode:      ${BOLD}PARALLEL${NC}"
  fi
  if $DRY_RUN; then
    info "Dry run complete. ${total} prompts previewed."
  else
    echo -e "${BOLD}Run Summary${NC}"
    echo -e "  ${GREEN}Passed:${NC}  $passed"
    echo -e "  ${RED}Failed:${NC}  $failed"
    if [[ $skipped -gt 0 ]]; then
      echo -e "  ${YELLOW}Skipped:${NC} $skipped"
    fi
    echo -e "  ${DIM}Log:${NC}     $log_file"

    # Append summary to log
    {
      echo ""
      echo "# Run Summary"
      echo "Finished: $(date -u '+%Y-%m-%dT%H:%M:%SZ')"
      echo "Passed:   $passed"
      echo "Failed:   $failed"
      echo "Skipped:  $skipped"
    } >> "$log_file"

    if [[ $failed -gt 0 ]]; then
      exit 1
    fi
  fi
}

main
